services:
  web:
    image: ${registry_url}/webapp:${image_tag}
    container_name: webapp
    expose:
      - "${app_port}"
    env_file:
      - .env
    restart: unless-stopped
  nginx:
    image: nginx:alpine
    restart: unless-stopped
    ports:
      - "80:80"
    volumes:
      - /opt/webapp/nginx.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      - web
